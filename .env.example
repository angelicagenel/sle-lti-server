# Copy this file to .env and fill in real values (never commit .env)

# Flask session secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace-with-random-hex-string

# Default workbook URL redirected to after LTI launch
DEFAULT_WORKBOOK_URL=https://your-org.github.io/sle-workbooks/test

# RSA keys — paste full PEM content (newlines as \n)
# Generate with:
#   openssl genrsa -out keys/private.key 4096
#   openssl rsa -in keys/private.key -pubout -out keys/public.key
SECRET_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
SECRET_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
